# Stellara 환경 변수 예시 — 실제 값을 채워 .env로 복사한 뒤 사용하세요.
# .env 파일은 .gitignore에 등록되어 있어 커밋되지 않습니다.

# ── Prokerala Astrology API (https://api.prokerala.com) ─────────────
# 발급 위치: https://api.prokerala.com/account/api-client
#
# 개발 권장 기본값:
# - UI/문서 작업만 할 때는 아래 값을 비워 두고 fixture 모드로 시작
# - 실 API 검증이 필요할 때만 값을 채우고 USE_FIXTURE_IN_DEBUG=false 로 전환
PROKERALA_CLIENT_ID=
PROKERALA_CLIENT_SECRET=

# 백업 credential (선택)
# 순차 fallback 순서:
# 1) primary
# 2) 서연 (SEOYEON)
# 3) 선우 (SEONWOO)
# 4) 도연 (DOYEON)
#
# primary credit 이 소진되거나 429가 발생하면 앱이 다음 credential 로 1회 전환을 시도합니다.
# 실값을 넣을 때만 주석을 해제하세요.
#
# PROKERALA_CLIENT_ID_SEOYEON=
# PROKERALA_CLIENT_SECRET_SEOYEON=
#
# PROKERALA_CLIENT_ID_SEONWOO=
# PROKERALA_CLIENT_SECRET_SEONWOO=
#
# PROKERALA_CLIENT_ID_DOYEON=
# PROKERALA_CLIENT_SECRET_DOYEON=

# Prokerala API 기본 URL. 보통 변경하지 않음.
PROKERALA_BASE_URL=https://api.prokerala.com
PROKERALA_TOKEN_URL=https://api.prokerala.com/token

# 디버그 모드에서 fixture(녹화된 응답)를 우선 사용해 credit 절약.
# true 로 두면 fixture 가 있는 호출은 네트워크를 타지 않습니다.
# 팀 기본값은 true 를 권장합니다. 실응답 검증 시에만 false 로 바꾸세요.
USE_FIXTURE_IN_DEBUG=true

# ── AI Question Providers (CONTENT-001 예정) ───────────────────────
# 메인 화면에는 raw model id 를 직접 노출하지 않고,
# `자동(추천) / GPT / Claude` 정도의 provider 선택만 보여주는 것을 권장합니다.
#
# 앱 연동에는 ChatGPT / Claude 대화형 앱 구독이 아니라 "API key" 가 필요합니다.
# 이 값들은 학교 프로젝트용 내부 데모 빌드에서만 사용하고, 공개 배포 빌드에는 넣지 마세요.
#
# 추천 기본값:
# - provider 기본 선택: auto
# - provider 순서: openai -> anthropic
# - OpenAI 기본 모델: gpt-5-mini
# - Anthropic 기본 모델: claude-3-5-haiku-latest
AI_PROVIDER_DEFAULT=auto
AI_PROVIDER_ORDER=openai,anthropic
AI_MODEL_OPENAI_DEFAULT=gpt-5-mini
AI_MODEL_ANTHROPIC_DEFAULT=claude-3-5-haiku-latest

# primary key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# backup key (선택)
# - 서연: 1차 대체 키
# - 선우: 2차 대체 키
# - 도연: 3차 대체 키
# 실값을 넣을 때만 주석을 해제하세요.
#
# OPENAI_API_KEY_SEOYEON=
# OPENAI_API_KEY_SEONWOO=
# OPENAI_API_KEY_DOYEON=
#
# ANTHROPIC_API_KEY_SEOYEON=
# ANTHROPIC_API_KEY_SEONWOO=
# ANTHROPIC_API_KEY_DOYEON=
